<script>
document.addEventListener('DOMContentLoaded', function () {
  var allRegions = document.querySelectorAll('.seltaris-region');
  var filterBtns = document.querySelectorAll('.filter-btn');
  var groups = document.querySelectorAll('.region-group'); // wrap each group in a .region-group div

  function filterDivs(filterClass) {
    groups.forEach(function(group) {
      var slides = group.querySelectorAll('.seltaris-region');
      var noResults = group.querySelector('.no-results');
      var sliderContainer = group.querySelector('.slider-container');
      var hasVisible = false;

      slides.forEach(function(div) {
        if (filterClass === 'all' || div.classList.contains(filterClass)) {
          div.style.display = ''; // show
          hasVisible = true;
        } else {
          div.style.display = 'none'; // hide
        }
      });

      // toggle no-results text
      if (noResults) {
        noResults.style.display = hasVisible ? 'none' : 'block';
      }

      // toggle slider-container
      if (sliderContainer) {
        sliderContainer.style.display = hasVisible ? '' : 'none';
      }
    });
  }

  function setActiveButton(activeBtn) {
    for (var i = 0; i < filterBtns.length; i++) {
      filterBtns[i].classList.remove('active');
    }
    activeBtn.classList.add('active');
  }

  function wire(btn, filterClass) {
    if (!btn) return;
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      filterDivs(filterClass);
      setActiveButton(btn);
    });
  }

  var auBtn  = document.querySelector('.seltaris-filter-au');
  var intBtn = document.querySelector('.seltaris-filter-int');
  var nzBtn  = document.querySelector('.seltaris-filter-nz');
  var allBtn = document.querySelector('.seltaris-filter-all');

  wire(auBtn,  'filter-au');
  wire(intBtn, 'filter-int');
  wire(nzBtn,  'filter-nz');
  wire(allBtn, 'all');

  // make "All" active by default
  if (allBtn) {
    setActiveButton(allBtn);
    filterDivs('all');
  }
});
</script>


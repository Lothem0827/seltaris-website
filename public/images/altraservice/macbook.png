<script>
jQuery(document).ready(function($) {
  $('[data-ep-wrapper-link]').each(function() {
    const $el = $(this);
    const raw = $el.attr('data-ep-wrapper-link');

    try {
      const parsed = JSON.parse(raw);
      let link = parsed.url;

      // Only update if it's a relative path
      if (link && link.startsWith('/')) {
        parsed.url = window.location.origin + link;
        $el.attr('data-ep-wrapper-link', JSON.stringify(parsed));
      }
    } catch (e) {
      console.warn('Could not parse wrapper link:', e);
    }
  });
});
</script>

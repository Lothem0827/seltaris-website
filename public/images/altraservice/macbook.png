<style>
	
/* Styles for both swiper buttons */
.swiper-button-next,
.swiper-button-prev,
.explore-card-container .swiper-button-next,
.explore-card-container .swiper-button-prev {
  background: rgba(0, 0, 0, 0.3);
  padding: 12px;
  border-radius: 1000px;
}

/* Styles for all swiper buttons */
.swiper-button-next,
.swiper-button-prev {
  height: fit-content;
  width: fit-content;
}

/* Styles for larger swiper buttons */
.explore-card-container .swiper-button-next,
.explore-card-container .swiper-button-prev {
  height: 52px;
  width: 52px;
}

/* Positioning for swiper buttons */
.swiper-button-next,
.explore-card-container .swiper-button-next {
  right: 24px;
}

.swiper-button-prev,
.explore-card-container .swiper-button-prev {
  left: 24px;
}

/* Hide arrow icons for all swiper buttons */
.swiper-button-prev::after,
.swiper-button-next::after {
  display: none;
}

/* Styles for disabled swiper buttons */
.swiper-button-disabled,
.swiper-button-prev.swiper-button-disabled,
.swiper-button-next.swiper-button-disabled,
.explore-card-container .swiper-button-disabled {
  opacity: 0;
}

/* SVG fill color for arrow icons */
.swiper-button-next svg,
.swiper-button-prev svg {
  fill: var(--e-global-color-4bc5fce);
}

</style>
<style>
	
/* Styles for snapslider cards */
.snapslider-card-last {
  opacity: 0;
  width: 225px !important;
}

.snapslider-card {
  display: block;
  padding: 0.5em;
  scroll-snap-align: start;
  transition: transform 0.3s ease;
}

.snapslider-card:hover {
  transform: scale(1.01);
}
	
.loop-carousel-card:hover {
  transform: scale(1.01);
}

.snapslider-card.large {
  width: 450px;
  height: 560px;
}

.snapslider-card.small {
  width: 400px;
  height: 515px;
}

.snapslider-card.two-content {
  display: flex;
  width: 400px;
  justify-content: space-between;
}

/* Styles for explore card content */
.explore-card-content {
  border-radius: 20px;
  background: var(--e-global-color-4bc5fce);
  width: 100%;
  height: 100%;
  box-shadow: 0px 0px 16px 0px rgba(25, 117, 255, 0.13);
}

.explore-card-content.small {
  height: 50%;
}

.explore-card-content-wrapper {
  height: 100%;
}

.explore-card--text {
  padding: var(--ms-padding);
}

.explore-card--image {
  padding: var(--xxs-padding);
  height: 55%;
}

.explore-card--image .image {
  background-size: cover;
  height: 100%;
  border-radius: 16px;
}

@media only screen and (max-width: 768px) {
  /* Responsive styles for smaller screens */
  .explore-card--text,
  .explore-card--image {
    padding: var(--xs-padding);
  }
}

/* Styles for explore card container */
.explore-card-container .snapslider-card {
  display: block;
  width: fit-content;
  height: fit-content;
  overflow-x: hidden;
  flex-grow: 0;
  flex-shrink: 0;
  scroll-snap-align: start;
}

.explore-card-container .ezd-snapslider {
  position: relative;
}

.explore-card-container .snapslider-scroll.swiper-wrapper {
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap;
  gap: var(--gap-1);
  -ms-overflow-style: none;
}

.explore-card-container .snapslider-scroll.swiper-wrapper::-webkit-scrollbar {
  display: none;
}

.explore-card-container .card-content {
  width: 100%;
  height: 100%;
}

</style>
<style>

@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap');

	:root {
			--hsf-global__font-family: "DM Sans", sans-serif;
			--hsf-field-input__border-radius: 10px;	
			--hsf-field-input__border-color: #BEC9FF;	
			--hsf-background__background-color: #fff;
			--hsf-background__border-radius	28px;
			--hsf-background__padding: 32px;	
			--hsf-field-label__font-size: 12px;
			--hsf-field-label__color: #3D4D83;
			--hsf-field-input__color: #3D4D83;	
			--hsf-erroralert__font-size: 12px;	
			--hsf-button__font-size: 16px;	
			--hsf-button__border-radius: 12px;
		  --hsf-button__padding: 16px;
	}

	.hsfc-Step {
		border-radius: 28px !important;
	}

	.hsfc-Heading {
		font-size: 11px;
		text-transform: uppercase;
		color: #9CA5C1 !important;
		letter-spacing: 1px;
	}

	.hsfc-FieldLabel {
		color: #3D4D83;
		font-style: normal;
		font-weight: 600;
		letter-spacing: 1.2px;
		text-transform: uppercase;
	}
	
	.hsfc-TextInput:focus {	
		outline: 2px solid #7680F3 !important; 
		border: 1px solid #7680F3 !important;
	}

	.hsfc-Button {
		width: 100% !important;
		border: 1px solid #0199F8 !important;
		background: linear-gradient(90deg, #1B8BDA -0.24%, #5115BE 100.24%) !important;
		box-shadow: 0 9px 40px 0 rgba(0, 143, 255, 0.60) !important;
	}

</style>
<style>
/* Styles for inline headings */
.inline-heading h1,
.inline-heading h2,
.inline-heading h3,
.inline-heading h4,
.inline-heading h5,
.inline-heading h6 {
  display: inline;
}

/* Styles for padding of explore headings */
.explore-heading-padding {
  padding-left: 100px;
}

/* Styles for padding of explore container */
.explore-container-padding {
  padding-top: 100px;
  padding-bottom: 80px;
  padding-left: 100px;
  padding-right: 100px;
}

/* Media queries for smaller screens */
@media only screen and (max-width: 1024px) {
  .snapslider-scroll,
  .explore-heading-padding {
    padding-left: 40px;
    padding-right: 40px;
  }
  .snapslider-card-first {
    opacity: 0;
    width: 8px !important;
  }
  .explore-container-padding {
    padding-top: 60px;
    padding-bottom: 60px;
    padding-left: 40px;
    padding-right: 40px;
  }
}

@media only screen and (max-width: 768px) {
  .snapslider-scroll,
  .explore-heading-padding {
    padding-left: 20px;
    padding-right: 20px;
  }
  .snapslider-card-first {
    opacity: 0;
    width: 0 !important;
  }
  .explore-container-padding {
    padding-top: 40px;
    padding-bottom: 40px;
    padding-left: 20px;
    padding-right: 20px;
  }
}

/* Dynamic Loop Carousel */

.elementor-loop-container .swiper-wrapper .e-loop-item {
  min-width: 450px !important; 

}

.elementor-loop-container .swiper-wrapper .e-loop-item .elementor-element {
  background-size: cover;
}

.swiper-slide.e-loop-item {
  width: fit-content !important;
}

.elementor-swiper-button.elementor-swiper-button-prev, .elementor-swiper-button.elementor-swiper-button-next {
    background: rgba(0, 0, 0, 0.3);
  padding: 13.5px;
  border-radius: 1000px;
}

.elementor-swiper-button.elementor-swiper-button-prev {
  margin-left: 24px;
}
.elementor-swiper-button.elementor-swiper-button-next {
  margin-right: 24px;
}

.swiper.elementor-loop-container {
  overflow: visible !important;
}

</style>

<style>
/* Base styles for explore popups */
.explore-popups,
.explore-popups-dark {
  padding: 60px;
  border-radius: var(--rounded-1);
}

/* Styles for light explore popups */
.explore-popups {
  background-color: var(--e-global-color-4bc5fce);
}

/* Styles for dark explore popups */
.explore-popups-dark {
  background-color: var(--e-global-color-e00bf05);
}

/* Common styles for headings in explore popups */
.explore-popups h1,
.explore-popups-dark h1,
.explore-popups h2 {
  font-family: var(--e-global-typography-6ca77f7-font-family) !important;
  font-weight: var(--e-global-typography-6ca77f7-font-weight) !important;
  line-height: var(--e-global-typography-6ca77f7-line-height) !important;
  letter-spacing: var(--e-global-typography-6ca77f7-letter-spacing) !important;
}

/* Styles for light h1 in explore popups */
.explore-popups h1 {

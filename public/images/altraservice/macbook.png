      type: "correction",
      id: "c13",
    },
    ],
    ];
    /**
     * Utility function to pause the animation.
     * @param {number} ms - Milliseconds to sleep.
     */
    function sleep(ms) {
      return new Promise(function(resolve) {
        setTimeout(resolve, ms);
      });
    }
    /**
     * Creates a deep copy of the sequence definition for a fresh run.
     * @param {Array} baseSequence - The specific sequence definition array to clone.
     */
    function cloneSequence(baseSequence) {
      return baseSequence.map(function(s) {
        var copy = {};
        for (var k in s) {
          // Simple shallow copy for configuration properties
          copy[k] = s[k];
        }
        copy.element = null; // Reset DOM element reference
        return copy;
      });
    }
    /**
     * Ensures the blinking cursor element is in the DOM and returned.
     * @param {HTMLElement} display - The container element.
     */
    function ensureCursor(display) {
      var cursor = document.getElementById("typing-cursor");
      if (!cursor) {
        // Create cursor if it was removed or doesn't exist
        cursor = document.createElement("span");
        cursor.id = "typing-cursor";
        cursor.className = "cursor";
        display.appendChild(cursor);
      }
      // Ensure it's the last child in the display container to appear at the end
      if (display.lastChild !== cursor) {
        display.appendChild(cursor);
      }
      return cursor;
    }
    /**
     * Step 1: Types the initial, uncorrected text for the current batch.
     */
    function typeInitialText(sequence, display, cursor) {
      display.innerHTML = ""; // Clear display for fresh typing of a new batch
      display.appendChild(cursor);
      cursor.style.display = "inline-block";
      return new Promise(function(resolve) {
        var segIndex = 0;
        function nextSeg() {
          if (segIndex >= sequence.length) {
            resolve();
            return;
          }
          var seg = sequence[segIndex];
          // Use 'initial' for correction types, 'text' for plain types
          var text = seg.type === "plain" ? seg.text: seg.initial;
          var i = 0;
          function typeChar() {
            if (i >= text.length) {
              segIndex++;
              nextSeg();
              return;
            }
            var ch = text.charAt(i);
            if (seg.type === "correction") {
              // If it's a correction segment, wrap it in a span
              if (!seg.element) {
                seg.element = document.createElement("span");
                seg.element.className = "highlight-span";
                display.insertBefore(seg.element, cursor);
              }
              // Appending the character to the span's text content
              seg.element.textContent += ch;
            } else {
              // Plain text is just inserted as a text node
              display.insertBefore(document.createTextNode(ch), cursor);
            }
            i++;
            setTimeout(typeChar, typingSpeed);
          }
          typeChar();
        }
        nextSeg();
      });
    }
    /**
     * Step 2: Highlights the error segments in red and pauses.
     */
    function highlightAndPause(sequence) {
      // Reduced delay after typing from 1500ms to 50ms for near-instant highlighting
      return sleep(50).then(function() {
        sequence.forEach(function(s) {
          // Only apply red highlight if it's a correction type AND NOT marked as immediate validation
          if (s.type === "correction" && s.element && !s.isValidation) {
            s.element.classList.add("red-highlight");
          }
        });
        return sleep(2000); // Pause for user to see the error highlights (kept at 2000ms)
      });
    }
    /**
     * Step 3: Replaces the initial text with the correct text segment by segment.
     */
    function correctText(sequence, cursor) {
      cursor.style.display = "none"; // Hide cursor during correction
      return new Promise(function(resolve) {
        var corr = sequence.filter(function(s) {
          return s.type === "correction";
        }); // Get all highlighted segments
        var idx = 0;
        function step() {
          if (idx >= corr.length) {
            resolve();
            return;
          }
          var segment = corr[idx];
          if (segment.element) {
            // Replace the content of the span with the correct value
            segment.element.textContent = segment.correct;
          }
          idx++;
          setTimeout(step, 150); // Fast replacement animation
        }
        step();
      }).then(function() {
        cursor.style.display = "inline-block"; // Show cursor again
      });
    }
    /**
     * Step 4: Transitions highlights from red to green (Success/Validation).
     */
    function transitionToGreen(sequence) {
      sequence.forEach(function(s) {
        if (s.type === "correction" && s.element) {
          s.element.classList.remove("red-highlight");
          s.element.classList.add("green-highlight");
        }
      });
      // Pause for user to see the successful correction/validation.
      return sleep(1500);
    }
    /**
     * Step 5: Clears the green highlights and removes the wrapping spans.
     * (Note: This function is no longer called in runAnimation, as requested)
     */
    function clearGreen(sequence) {
      sequence.forEach(function(s) {
        if (s.type === "correction" && s.element) {
          s.element.classList.remove("green-highlight");
          // Remove the span wrapper to leave only text content for a cleaner look
          var parent = s.element.parentNode;
          if (parent) {
            // Insert all child nodes (the corrected text) before the span
            while (s.element.firstChild) {
              parent.insertBefore(s.element.firstChild, s.element);
            }
            // Then remove the empty span itself
            parent.removeChild(s.element);
            s.element = null; // Clear reference
          }
        }
      });
    }
    /**
     * Main animation loop driver. Executes one sequence and prepares for the next.
     */
    function runAnimation() {
      var display = document.getElementById("address-display");
      var cursor = ensureCursor(display);
      // Get the current base sequence data and clone it
      var baseSequence = animationSequences[currentSequenceIndex];
      var sequence = cloneSequence(baseSequence);
      // Define the full animation promise chain for this sequence
      var animationPromise = typeInitialText(sequence, display, cursor)
      .then(function() {
        return highlightAndPause(sequence);
      })
      .then(function() {
        return correctText(sequence, cursor);
      })
      .then(function() {
        // Pause here on the green highlighted state.
        return transitionToGreen(sequence);
      });
      // The steps that displayed plain text and extra pauses have been removed.
      // After the current sequence finishes, update the index and start the next one
      animationPromise.then(function() {
        currentSequenceIndex++;
        if (currentSequenceIndex >= animationSequences.length) {
          currentSequenceIndex = 0; // Loop back to the start
        }
        // The next runAnimation call starts by clearing the display and typing immediately.
        return runAnimation();
      });
    }
    // Start the animation immediately after the DOM is ready (or script loads)
    window.onload = runAnimation;
  })();
</script>
<script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@0.2.28/bundled/lenis.js"></script>

<script>
const lenis = new Lenis({
  duration: 1.2, // Scroll duration
  easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // Easing function for smooth transitions
  direction: 'vertical', // Scroll direction: vertical or horizontal
  gestureDirection: 'vertical', // Gesture direction: vertical, horizontal, or both
  smooth: true, // Enable smooth scrolling
  mouseMultiplier: 1, // Mouse scroll speed multiplier
  smoothTouch: false, // Disable smooth scrolling for touch devices
  touchMultiplier: 2, // Touch scroll speed multiplier
  infinite: false, // Disable infinite scroll
});

// Optional: Listen to scroll events
lenis.on('scroll', ({ scroll, limit, velocity, direction, progress }) => {
  console.log({ scroll, limit, velocity, direction, progress });
});

// Animation frame loop function
function raf(time) {
  lenis.raf(time);
  requestAnimationFrame(raf);
}
requestAnimationFrame(raf);
</script>



<style>
    
    html  {
    scroll-behavior: auto !important; /* Disables default smooth scrolling */
}
    
    
</style>
<script>
document.addEventListener('DOMContentLoaded', () => {
    // 1. Target all accordion component groups on the page
    const accordionGroups = document.querySelectorAll('.seltaris-custom-accordion-group');

    accordionGroups.forEach(group => {
        const accordionItems = group.querySelectorAll('.seltaris-custom-accordion-item');
        const targetImageElement = group.querySelector('.seltaris-custom-accordion-image img');

        // Preload images scoped to this specific group to prevent network pop-in lag
        accordionItems.forEach(item => {
            const imgSrc = item.getAttribute('data-image');
            if (imgSrc) {
                const img = new Image();
                img.src = imgSrc;
            }
        });

        // 2. Handle clicks within this specific group
        accordionItems.forEach(item => {
            item.addEventListener('click', (e) => {
                if (e.target.closest('.seltaris-custom-accordion-content')) return;

                const isOpen = item.classList.contains('active');

                // Collapse only items inside THIS group
                accordionItems.forEach(otherItem => {
                    otherItem.classList.remove('active');
                });

                // Open clicked item and instantly map its specific data-image
                if (!isOpen) {
                    item.classList.add('active');

                    const newImgSrc = item.getAttribute('data-image');
                    if (targetImageElement && newImgSrc) {
                        targetImageElement.src = newImgSrc;
                        
                        if (targetImageElement.hasAttribute('srcset')) {
                            targetImageElement.removeAttribute('srcset');
                        }
                    }
                }
            });
        });
    });
});
</script>

<style>
/* --- Elementor Layout Overrides --- */
.seltaris-custom-accordion-item {
    cursor: pointer;
}

.seltaris-custom-accordion-item .seltaris-custom-accordion-content {
    display: none !important;
}

.seltaris-custom-accordion-item.active .seltaris-custom-accordion-content {
    display: block !important;
}

/* --- SVG Icon States --- */

/* 1. Default Collapsed State (+ shows, - hidden) */
.seltaris-custom-accordion-item .seltaris-icon-minus,
.seltaris-custom-accordion-item .seltaris-icon-minus svg {
    display: none !important;
}

.seltaris-custom-accordion-item .seltaris-icon-plus,
.seltaris-custom-accordion-item .seltaris-icon-plus svg {
    display: inline-block !important;
}

/* 2. Expanded State (active) (- shows, + hidden) */
.seltaris-custom-accordion-item.active .seltaris-icon-plus,
.seltaris-custom-accordion-item.active .seltaris-icon-plus svg {
    display: none !important;
}

.seltaris-custom-accordion-item.active .seltaris-icon-minus,
.seltaris-custom-accordion-item.active .seltaris-icon-minus svg {
    display: inline-block !important;
}

/* --- Optimized Transition --- */
.seltaris-custom-accordion-image img {
    transition: opacity 0.15s ease-in-out;
}
</style>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" ></script>
	

<script >

	var swiper = new Swiper(".seltaris-swiper", { 
		speed: 1000, 
		navigation: { 
			nextEl: ".seltaris-swiper-button-next", 
			prevEl: ".seltaris-swiper-button-prev", 
		}, 
		slidesPerView: "auto", 
	});

	document.addEventListener('DOMContentLoaded', function () {
		document.querySelectorAll('.seltaris-swiper').forEach(function (container) {
			// Expect IDs like "seltaris-swiper-1"
			var m = (container.id || '').match(/(\d+)$/);
			if (!m) { console.warn('No numeric suffix in id for', container); return; }

			var n = m[1];
			var prevBtn = document.getElementById('seltaris-' + n + '-prev');
			var nextBtn = document.getElementById('seltaris-' + n + '-next');

			if (!prevBtn || !nextBtn) {
				console.warn('Missing nav buttons for slider #' + n);
				return;
			}

			// Prevent double init
			if (container.swiper) container.swiper.destroy(true, true);

			new Swiper(container, {
				speed: 1000,
				slidesPerView: 'auto',
				navigation: {
					prevEl: prevBtn,
					nextEl: nextBtn,
				},
			});
		});
	});




</script>



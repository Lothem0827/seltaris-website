				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/headshot/headshotsix.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/headshot/headshotseven.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/headshot/headshoteight.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/headshot/headshotnine.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/headshot/headshotten.jpg"
		];

		var circleImages = [
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/circle/circleone.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/circle/circletwo.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/circle/circlethree.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/circle/circlefour.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/circle/circlefive.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/circle/circlesix.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/circle/circleseven.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/circle/circleeight.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/circle/circlenine.jpg",
				"https://media.datatools.com.au/datatools_website/global_assets/data_quality_specialists_images/circle/circleten.jpg"
		];

		// Function to shuffle the array
		function shuffleArray(array) {
			var currentIndex = array.length,
				temporaryValue,
				randomIndex;

			while (currentIndex !== 0) {
				randomIndex = Math.floor(Math.random() * currentIndex);
				currentIndex -= 1;

				temporaryValue = array[currentIndex];
				array[currentIndex] = array[randomIndex];
				array[randomIndex] = temporaryValue;
			}

			return array;
		}

		// Shuffle the images array
		var shuffledImages = shuffleArray(headshotImages);

		var imgElements = document.querySelectorAll(".random-image .image-wrapper");
		imgElements.forEach(function (imgElement, index) {
			imgElement.style.backgroundImage =
				"url(" + shuffledImages[index % shuffledImages.length] + ")";
		});

		var shuffledCircleImages = shuffleArray(circleImages);

		var imgCircleElements = document.querySelectorAll(
			".random-circle-image img"
		);
		imgCircleElements.forEach(function (imgElement, index) {
			console.log(imgElement)
			imgElement.setAttribute('srcset', '');
			imgElement.src = shuffledCircleImages[index % shuffledCircleImages.length]
		});
	};


</script>
<script>
// ---- rAF polyfill (simple) ----
(function() {
  var lastTime = 0;
  var vendors = ['ms', 'moz', 'webkit', 'o'];
  for (var x = 0; x < vendors.length && !window.requestAnimationFrame; ++x) {
    window.requestAnimationFrame = window[vendors[x] + 'RequestAnimationFrame'];
    window.cancelAnimationFrame =
      window[vendors[x] + 'CancelAnimationFrame'] ||
      window[vendors[x] + 'CancelRequestAnimationFrame'];
  }
  if (!window.requestAnimationFrame) {
    window.requestAnimationFrame = function(callback) {
      var currTime = new Date().getTime();
      var timeToCall = Math.max(0, 16 - (currTime - lastTime));
      var id = window.setTimeout(function() { callback(currTime + timeToCall); }, timeToCall);
      lastTime = currTime + timeToCall;
      return id;
    };
  }
  if (!window.cancelAnimationFrame) {
    window.cancelAnimationFrame = function(id) {
      clearTimeout(id);
    };
  }
})();

// ---- Particle Animation for each canvas ----
function ParticleCanvas(canvas) {
  var ctx = canvas.getContext('2d');
  var particles = [];
  var PARTICLE_COUNT = 40;
  var MAX_RADIUS = 1.5;
  var MIN_RADIUS = 0.5;
  var SLOW_SPEED_FACTOR = 0.15;

  function Particle(x, y, radius, velocityX, velocityY) {
    this.x = x;
    this.y = y;
    this.radius = radius;
    this.velocityX = velocityX;
    this.velocityY = velocityY;
    this.opacity = 0.5 + Math.random() * 0.5;
  }

  Particle.prototype.draw = function() {
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2, false);
    ctx.fillStyle = 'rgba(255, 255, 255, ' + this.opacity + ')';
    ctx.fill();
  };

  Particle.prototype.update = function() {
    this.x += this.velocityX;
    this.y += this.velocityY;

    // Wrap edges
    if (this.x < 0) this.x = canvas.width;
    if (this.x > canvas.width) this.x = 0;
    if (this.y < 0) this.y = canvas.height;
    if (this.y > canvas.height) this.y = 0;

    this.draw();
  };

  function initParticles() {
    particles = [];
    for (var i = 0; i < PARTICLE_COUNT; i++) {
      var x = Math.random() * canvas.width;
      var y = Math.random() * canvas.height;
      var radius = Math.random() * (MAX_RADIUS - MIN_RADIUS) + MIN_RADIUS;
      var velocityX = (Math.random() - 0.5) * SLOW_SPEED_FACTOR;
      var velocityY = (Math.random() - 0.5) * SLOW_SPEED_FACTOR;

      particles.push(new Particle(x, y, radius, velocityX, velocityY));
    }
  }

  function animate() {
    requestAnimationFrame(animate);
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (var i = 0; i < particles.length; i++) {
      particles[i].update();
    }
  }

  // init
  initParticles();
  animate();
}

// ---- Initialize all canvases with class "particleCanvas" ----
var canvases = document.querySelectorAll('.particleCanvas');
for (var i = 0; i < canvases.length; i++) {
  ParticleCanvas(canvases[i]);
}
</script>

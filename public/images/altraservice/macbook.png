<script>
document.addEventListener('DOMContentLoaded', function() {
    // 1. Find all wrappers (instances)
    var wrappers = document.querySelectorAll('.tabs-wrapper');

    for (var i = 0; i < wrappers.length; i++) {
        (function() {
            var wrapper = wrappers[i];
            var tabs = wrapper.querySelectorAll('.tab-link');
            var contents = wrapper.querySelectorAll('.tab-content');

            for (var j = 0; j < tabs.length; j++) {
                (function(index) {
                    var tab = tabs[index];
                    
                    // Added 'e' here to access the click event
                    tab.addEventListener('click', function(e) {
                        // FIX: Prevents the page from scrolling to the top
                        e.preventDefault(); 
                        
                        // 3. Remove active classes ONLY within this wrapper
                        for (var k = 0; k < tabs.length; k++) {
                            tabs[k].classList.remove('active-btn');
                        }
                        for (var l = 0; l < contents.length; l++) {
                            contents[l].classList.remove('active-content');
                        }

                        // 4. Set active states for the clicked item
                        this.classList.add('active-btn');
                        if (contents[index]) {
                            contents[index].classList.add('active-content');
                        }
                    });
                })(j);
            }
        })();
    }
});
</script>
